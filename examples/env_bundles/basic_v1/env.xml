<mujoco model="basic_v1" xmlns:kiln="urn:kiln:mjcf:v1" kiln:schema_version="1" kiln:up_axis="z">
  <asset>
    <mesh name="scene_world_mesh" file="scene.usda"/>
  </asset>

  <worldbody>
    <body name="world" pos="0 0 0" quat="1 0 0 0">
      <geom name="world_geom" type="mesh" mesh="scene_world_mesh"/>
      <kiln:world source_file="scene.usda" fixed="true" collision="true" visualization="true" scale="1.0"/>
    </body>

    <body name="box1" pos="0 0 0.6" quat="1 0 0 0">
      <geom name="box1_geom" type="box" size="0.5 0.5 0.5" mass="1.0" rgba="1.0 0.1 0.1 1.0"/>
      <kiln:primitive id="box1" shape="box"/>
    </body>

    <body name="sphere1" pos="2 0 0.6" quat="1 0 0 0">
      <geom name="sphere1_geom" type="sphere" size="0.5" mass="1.0" rgba="0.1 0.9 0.2 1.0"/>
      <kiln:primitive id="sphere1" shape="sphere"/>
    </body>

    <body name="cylinder1" pos="-2 0 0.6" quat="1 0 0 0">
      <geom name="cylinder1_geom" type="cylinder" size="0.4 0.5" mass="1.0" rgba="0.2 0.4 1.0 1.0"/>
      <kiln:primitive id="cylinder1" shape="cylinder"/>
    </body>

    <body name="plane1" pos="0 0 -0.2" quat="1 0 0 0">
      <geom name="plane1_geom" type="plane" size="20 20 1" rgba="0.3 0.3 0.3 1.0"/>
      <kiln:primitive id="plane1" shape="plane" normal="0 0 1"/>
    </body>
  </worldbody>

  <kiln:spawn_points>
    <kiln:spawn name="default" pos="0 0 1.2" quat="1 0 0 0"/>
    <kiln:spawn name="alt" pos="3 3 1.2" quat="1 0 0 0"/>
  </kiln:spawn_points>
</mujoco>
